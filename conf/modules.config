/*
~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~
    Config file for defining DSL2 per module options and publishing paths
~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~
    Available keys to override module options:
        ext.args   = Additional arguments appended to command in module.
        ext.args2  = Second set of arguments appended to command in module (multi-tool modules).
        ext.args3  = Third set of arguments appended to command in module (multi-tool modules).
        ext.prefix = File name prefix for output files.
----------------------------------------------------------------------------------------
*/

process {

    publishDir = [
        path: { "${params.outdir}/${task.process.tokenize(':')[-1].tokenize('_')[0].toLowerCase()}" },
        mode: params.publish_dir_mode,
        saveAs: { filename -> filename.equals('versions.yml') ? null : filename }
    ]

}

params {

    // gnomAD files
    controlCountPrefix=params.controlDataFolder + "/genotypeCount/gnomad."
    controlCountSuffix=".vcf.bgz.gds"
    controlAnnoPrefix=params.controlDataFolder + "/annotation/chr"
    controlAnnoSuffix=".annovar.vep.vcf.gz.gds"
    controlBed=params.controlDataFolder + "/coverage10x.bed.gz"

    // gnomAD PC and population
    gnomADPCPosition=params.controlDataFolder + "/ancestry/hail_positions.chr.pos.tsv"
    loadingPath=params.controlDataFolder + "/ancestry/gnomad.pca_loadings.ht"
    rfModelPath=params.controlDataFolder + "/ancestry/gnomad.RF_fit.onnx"

    // VEP
    AM=params.vepFolder + "/other_data/AlphaMissense"
    REVEL=params.vepFolder + "/other_data/REVEL"

    // reference
    refFASTA=params.controlDataFolder + "/reference.fasta.gz"

}
